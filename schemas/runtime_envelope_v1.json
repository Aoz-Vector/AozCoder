{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vexcoder.com/schemas/runtime_envelope_v1.json",
  "title": "RuntimeEnvelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "task_id",
    "turn",
    "seq",
    "event_id",
    "emitted_at",
    "source",
    "event"
  ],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "turn": { "type": "integer", "minimum": 1 },
    "seq": { "type": "integer", "minimum": 1 },
    "event_id": { "type": "string", "minLength": 1 },
    "emitted_at": { "$ref": "#/$defs/timestamp" },
    "source": { "$ref": "#/$defs/envelope_source" },
    "request_id": { "type": ["string", "null"], "minLength": 1 },
    "parent_event_id": { "type": ["string", "null"], "minLength": 1 },
    "event": { "$ref": "#/$defs/runtime_event" }
  },
  "$defs": {
    "tool_call_id": {
      "type": "string",
      "pattern": "^tx_[0-9]+_[0-9a-f]{4}$"
    },
    "tool_name": {
      "type": "string",
      "pattern": "^([a-z][a-z0-9_-]*|mcp\\.[a-z][a-z0-9_-]*\\.[a-z][a-z0-9_-]*)$"
    },
    "scope": {
      "type": "string",
      "enum": ["once", "session"]
    },
    "tool_status": {
      "type": "string",
      "enum": ["pending", "waiting_approval", "executing", "complete", "error", "cancelled"]
    },
    "assistant_phase": {
      "type": "string",
      "enum": ["thinking", "final"]
    },
    "envelope_source": {
      "type": "string",
      "enum": ["model", "runtime", "user_request", "system"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "output"],
      "properties": {
        "input": { "type": "integer", "minimum": 0 },
        "output": { "type": "integer", "minimum": 0 },
        "estimated": { "type": "boolean", "default": false }
      }
    },
    "validation_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "exit_code", "stdout_tail", "stderr_tail"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "exit_code": { "type": "integer" },
        "stdout_tail": { "type": "string" },
        "stderr_tail": { "type": "string" }
      }
    },
    "stream_block": {
      "oneOf": [
        { "$ref": "#/$defs/stream_block_thinking" },
        { "$ref": "#/$defs/stream_block_tool_call" },
        { "$ref": "#/$defs/stream_block_tool_result" },
        { "$ref": "#/$defs/stream_block_final_text" }
      ]
    },
    "stream_block_thinking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "content", "collapsed"],
      "properties": {
        "type": { "const": "thinking" },
        "content": { "type": "string" },
        "collapsed": { "type": "boolean" }
      }
    },
    "stream_block_tool_call": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "name", "input", "status"],
      "properties": {
        "type": { "const": "tool_call" },
        "id": { "type": "string", "minLength": 1 },
        "name": { "$ref": "#/$defs/tool_name" },
        "input": { "type": "object" },
        "status": { "$ref": "#/$defs/tool_status" }
      }
    },
    "stream_block_tool_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tool_call_id", "output", "is_error"],
      "properties": {
        "type": { "const": "tool_result" },
        "tool_call_id": { "type": "string", "minLength": 1 },
        "output": { "type": "string" },
        "is_error": { "type": "boolean" }
      }
    },
    "stream_block_final_text": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "content"],
      "properties": {
        "type": { "const": "final_text" },
        "content": { "type": "string" }
      }
    },
    "runtime_event": {
      "oneOf": [
        { "$ref": "#/$defs/turn_start" },
        { "$ref": "#/$defs/transcript_line" },
        { "$ref": "#/$defs/transcript_block_start" },
        { "$ref": "#/$defs/transcript_block_delta" },
        { "$ref": "#/$defs/transcript_block_complete" },
        { "$ref": "#/$defs/tool_call_status_updated" },
        { "$ref": "#/$defs/transcript_block_phase_updated" },
        { "$ref": "#/$defs/tool_call_started" },
        { "$ref": "#/$defs/tool_call_arguments_delta" },
        { "$ref": "#/$defs/tool_call_completed" },
        { "$ref": "#/$defs/tool_call_failed" },
        { "$ref": "#/$defs/approval_request" },
        { "$ref": "#/$defs/approval_resolved" },
        { "$ref": "#/$defs/validation_result" },
        { "$ref": "#/$defs/turn_end" },
        { "$ref": "#/$defs/error" },
        { "$ref": "#/$defs/max_turns_reached" }
      ]
    },
    "turn_start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "turn_start" },
        "input": { "type": ["string", "null"] }
      }
    },
    "transcript_line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "line"],
      "properties": {
        "type": { "const": "transcript_line" },
        "line": { "type": "string" }
      }
    },
    "transcript_block_start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "index", "block"],
      "properties": {
        "type": { "const": "transcript_block_start" },
        "index": { "type": "integer", "minimum": 0 },
        "block": { "$ref": "#/$defs/stream_block" }
      }
    },
    "transcript_block_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "index", "delta"],
      "properties": {
        "type": { "const": "transcript_block_delta" },
        "index": { "type": "integer", "minimum": 0 },
        "delta": { "type": "string" }
      }
    },
    "transcript_block_complete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "index"],
      "properties": {
        "type": { "const": "transcript_block_complete" },
        "index": { "type": "integer", "minimum": 0 }
      }
    },
    "tool_call_status_updated": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tool_call_id", "status"],
      "properties": {
        "type": { "const": "tool_call_status_updated" },
        "tool_call_id": { "$ref": "#/$defs/tool_call_id" },
        "status": { "$ref": "#/$defs/tool_status" }
      }
    },
    "transcript_block_phase_updated": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "index", "phase", "streaming"],
      "properties": {
        "type": { "const": "transcript_block_phase_updated" },
        "index": { "type": "integer", "minimum": 0 },
        "phase": { "$ref": "#/$defs/assistant_phase" },
        "streaming": { "type": "boolean" }
      }
    },
    "tool_call_started": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tool_call_id", "tool_name", "arguments", "status", "started_at"],
      "properties": {
        "type": { "const": "tool_call_started" },
        "tool_call_id": { "$ref": "#/$defs/tool_call_id" },
        "tool_name": { "$ref": "#/$defs/tool_name" },
        "arguments": { "type": "object" },
        "status": { "$ref": "#/$defs/tool_status" },
        "started_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "tool_call_arguments_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tool_call_id", "delta", "status", "invalid_json"],
      "properties": {
        "type": { "const": "tool_call_arguments_delta" },
        "tool_call_id": { "$ref": "#/$defs/tool_call_id" },
        "tool_name": {
          "oneOf": [
            { "$ref": "#/$defs/tool_name" },
            { "type": "null" }
          ]
        },
        "delta": { "type": "string" },
        "status": { "$ref": "#/$defs/tool_status" },
        "invalid_json": { "type": "boolean", "default": false }
      }
    },
    "tool_call_completed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tool_call_id", "status", "completed_at", "output"],
      "properties": {
        "type": { "const": "tool_call_completed" },
        "tool_call_id": { "$ref": "#/$defs/tool_call_id" },
        "tool_name": {
          "oneOf": [
            { "$ref": "#/$defs/tool_name" },
            { "type": "null" }
          ]
        },
        "status": { "const": "complete" },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "completed_at": { "$ref": "#/$defs/timestamp" },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "output": { "type": "string" }
      }
    },
    "tool_call_failed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tool_call_id", "status", "completed_at", "output"],
      "properties": {
        "type": { "const": "tool_call_failed" },
        "tool_call_id": { "$ref": "#/$defs/tool_call_id" },
        "tool_name": {
          "oneOf": [
            { "$ref": "#/$defs/tool_name" },
            { "type": "null" }
          ]
        },
        "status": { "const": "error" },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "completed_at": { "$ref": "#/$defs/timestamp" },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "output": { "type": "string" }
      }
    },
    "approval_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "capability", "scope"],
      "properties": {
        "type": { "const": "approval_request" },
        "capability": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/scope" },
        "tool_name": { "type": ["string", "null"] }
      }
    },
    "approval_resolved": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "capability", "scope", "approved"],
      "properties": {
        "type": { "const": "approval_resolved" },
        "capability": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/scope" },
        "approved": { "type": "boolean" }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "passed", "outputs"],
      "properties": {
        "type": { "const": "validation_result" },
        "passed": { "type": "boolean" },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/validation_output" }
        }
      }
    },
    "turn_end": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "status", "changed_files"],
      "properties": {
        "type": { "const": "turn_end" },
        "status": {
          "type": "string",
          "enum": ["completed", "failed", "cancelled"]
        },
        "usage": {
          "oneOf": [
            { "$ref": "#/$defs/token_usage" },
            { "type": "null" }
          ]
        },
        "changed_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "code", "message", "recoverable"],
      "properties": {
        "type": { "const": "error" },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "recoverable": { "type": "boolean" }
      }
    },
    "max_turns_reached": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "max_turns"],
      "properties": {
        "type": { "const": "max_turns_reached" },
        "max_turns": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
